import React, { useState, useEffect } from 'react';
import { View, Text, TextInput, TouchableOpacity, StyleSheet, Alert, KeyboardAvoidingView, Platform, ActivityIndicator } from 'react-native';
import * as SecureStore from 'expo-secure-store';
import { router } from 'expo-router';
import * as Speech from 'expo-speech';

// Mock API functions for now since backend is pending
const mockSendOtp = async (phone) => {
  return new Promise(resolve => setTimeout(() => resolve({ success: true }), 1000));
};

const mockVerifyOtp = async (phone, otp) => {
  return new Promise(resolve => {
    setTimeout(() => {
      // Accept any 4 digit OTP for mockup, fail otherwise
      if (otp.length >= 4) {
        resolve({ success: true, token: 'fake-jwt-token-12345' });
      } else {
        resolve({ success: false, message: 'Invalid OTP' });
      }
    }, 1000);
  });
};

export default function LoginScreen() {
  const [phoneNumber, setPhoneNumber] = useState('');
  const [otp, setOtp] = useState('');
  const [step, setStep] = useState(1); // 1 = Phone input, 2 = OTP input
  const [isLoading, setIsLoading] = useState(false);

  // Check if user is already logged in
  useEffect(() => {
    const checkToken = async () => {
      try {
        const token = await SecureStore.getItemAsync('session_token');
        if (token) {
          // If token exists, navigate to main tabs
          // router.replace('/(tabs)');
          // We won't redirect automatically here so you can test the login screen
        }
      } catch (e) {
        console.error('Failed to load token', e);
      }
    };
    checkToken();
    Speech.speak('आपका स्वागत है। कृपया अपना मोबाइल नंबर दर्ज करें।', { language: 'hi-IN' });
  }, []);

  const handleSendOtp = async () => {
    if (phoneNumber.length < 10) {
      Alert.alert('त्रुटि', 'कृपया सही मोबाइल नंबर दर्ज करें (10 अंक)');
      return;
    }

    setIsLoading(true);
    try {
      const response = await mockSendOtp(phoneNumber);
      if (response.success) {
        setStep(2);
        Speech.speak('ओटीपी (OTP) भेजा गया है। कृपया मेसेज चेक करें।', { language: 'hi-IN' });
      } else {
        Alert.alert('त्रुटि', 'OTP भेजने में विफल');
      }
    } catch (error) {
      Alert.alert('त्रुटि', 'सर्वर से कनेक्ट नहीं हो सका');
    } finally {
      setIsLoading(false);
    }
  };

  const handleVerifyOtp = async () => {
    if (otp.length < 4) {
      Alert.alert('त्रुटि', 'कृपया सही OTP दर्ज करें');
      return;
    }

    setIsLoading(true);
    try {
      const response = await mockVerifyOtp(phoneNumber, otp);
      if (response.success) {
        // Store JWT Session Token safely
        await SecureStore.setItemAsync('session_token', response.token);
        await SecureStore.setItemAsync('farmer_phone', phoneNumber);

        Speech.speak('लॉगिन सफल।', { language: 'hi-IN' });
        router.replace('/(tabs)'); // Navigate back to the home screen
      } else {
        Alert.alert('त्रुटि', response.message || 'OTP गलत है');
      }
    } catch (error) {
      Alert.alert('त्रुटि', 'सर्वर से कनेक्ट नहीं हो सका');
    } finally {
      setIsLoading(false);
    }
  };

  return (
    <KeyboardAvoidingView
      style={styles.container}
      behavior={Platform.OS === 'ios' ? 'padding' : 'height'}
    >
      <View style={styles.card}>
        <Text style={styles.title}>NeoAgri</Text>
        <Text style={styles.subtitle}>
          {step === 1 ? 'लॉगिन (Login)' : 'OTP दर्ज करें (Enter OTP)'}
        </Text>

        {step === 1 ? (
          <>
            <Text style={styles.label}>मोबाइल नंबर (Mobile Number)</Text>
            <View style={styles.inputContainer}>
              <Text style={styles.prefix}>+91</Text>
              <TextInput
                style={styles.input}
                placeholder="1234567890"
                keyboardType="phone-pad"
                maxLength={10}
                value={phoneNumber}
                onChangeText={setPhoneNumber}
                editable={!isLoading}
              />
            </View>
            <TouchableOpacity
              style={[styles.btn, isLoading && styles.btnDisabled]}
              onPress={handleSendOtp}
              disabled={isLoading}
            >
              {isLoading ? (
                <ActivityIndicator color="#fff" />
              ) : (
                <Text style={styles.btnText}>OTP भेजें (Request OTP)</Text>
              )}
            </TouchableOpacity>
          </>
        ) : (
          <>
            <Text style={styles.label}>OTP दर्ज करें (Enter OTP sent via SMS)</Text>
            <TextInput
              style={[styles.input, styles.otpInput]}
              placeholder="----"
              keyboardType="number-pad"
              maxLength={6}
              value={otp}
              onChangeText={setOtp}
              editable={!isLoading}
              // The magic properties that trigger SMS auto-fill on Android:
              textContentType="oneTimeCode"
              autoComplete="sms-otp"
            />
            <TouchableOpacity
              style={[styles.btn, isLoading && styles.btnDisabled]}
              onPress={handleVerifyOtp}
              disabled={isLoading}
            >
              {isLoading ? (
                <ActivityIndicator color="#fff" />
              ) : (
                <Text style={styles.btnText}>सत्यापित करें (Verify Info)</Text>
              )}
            </TouchableOpacity>

            <TouchableOpacity
              style={styles.secondaryBtn}
              onPress={() => setStep(1)}
              disabled={isLoading}
            >
              <Text style={styles.secondaryBtnText}>नंबर बदलें (Change Number)</Text>
            </TouchableOpacity>
          </>
        )}
      </View>
    </KeyboardAvoidingView>
  );
}

const styles = StyleSheet.create({
  container: {
    flex: 1,
    backgroundColor: '#F5FCFF',
    justifyContent: 'center',
    padding: 20,
  },
  card: {
    backgroundColor: '#fff',
    padding: 30,
    borderRadius: 20,
    elevation: 5,
    shadowColor: '#000',
    shadowOffset: { width: 0, height: 2 },
    shadowOpacity: 0.1,
    shadowRadius: 8,
  },
  title: {
    fontSize: 32,
    fontWeight: 'bold',
    color: '#27ae60',
    textAlign: 'center',
    marginBottom: 10,
  },
  subtitle: {
    fontSize: 18,
    color: '#34495e',
    textAlign: 'center',
    marginBottom: 30,
    fontWeight: '600',
  },
  label: {
    fontSize: 14,
    color: '#7f8c8d',
    marginBottom: 8,
  },
  inputContainer: {
    flexDirection: 'row',
    alignItems: 'center',
    borderWidth: 1.5,
    borderColor: '#bdc3c7',
    borderRadius: 12,
    marginBottom: 20,
    backgroundColor: '#ecf0f1',
  },
  prefix: {
    paddingHorizontal: 15,
    fontSize: 18,
    color: '#2c3e50',
    fontWeight: 'bold',
    borderRightWidth: 1,
    borderRightColor: '#bdc3c7',
  },
  input: {
    flex: 1,
    padding: 15,
    fontSize: 18,
    color: '#2c3e50',
  },
  otpInput: {
    borderWidth: 1.5,
    borderColor: '#bdc3c7',
    borderRadius: 12,
    backgroundColor: '#ecf0f1',
    textAlign: 'center',
    fontSize: 24,
    letterSpacing: 5,
    fontWeight: 'bold',
    marginBottom: 20,
  },
  btn: {
    backgroundColor: '#27ae60',
    padding: 16,
    borderRadius: 12,
    alignItems: 'center',
    marginTop: 10,
  },
  btnDisabled: {
    backgroundColor: '#95a5a6',
  },
  btnText: {
    color: '#fff',
    fontSize: 18,
    fontWeight: 'bold',
  },
  secondaryBtn: {
    marginTop: 15,
    alignItems: 'center',
    padding: 10,
  },
  secondaryBtnText: {
    color: '#2980b9',
    fontSize: 16,
    fontWeight: '500',
  }
});
